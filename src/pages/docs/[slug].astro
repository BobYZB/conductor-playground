---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PdfViewer from '../../components/PdfViewer';
import { formatDate } from '../../lib/format';
import { withBase } from '../../lib/paths';

export async function getStaticPaths() {
  const docs = await getCollection(
    'docs',
    ({ data }) => !data.draft && data.docType === 'pdf' && Boolean(data.pdfPath),
  );

  return docs.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const pdfUrl = withBase(entry.data.pdfPath ?? '');
---

<BaseLayout
  title={`${entry.data.title} | Farmerville`}
  description={entry.data.summary}
  contentClass="page-content--reader"
>
  <section class="doc-hero doc-hero--reader">
    <div class="doc-hero__content">
      <p class="section-kicker">{entry.data.category}</p>
      <h1>{entry.data.title}</h1>
      <p class="doc-hero__summary">{entry.data.summary}</p>
      <div class="doc-meta">
        <span>发布时间：{formatDate(entry.data.publishedAt)}</span>
        <span>最近更新：{formatDate(entry.data.updatedAt ?? entry.data.publishedAt)}</span>
      </div>
      <div class="tag-row">
        {entry.data.tags.map((tag) => <span class="tag-chip">{tag}</span>)}
      </div>
      <div class="hero__actions">
        <a class="button button--primary" href={pdfUrl} target="_blank" rel="noreferrer">打开原始 PDF</a>
        <a class="button button--secondary" href={withBase('/library/')}>返回文档库</a>
      </div>
    </div>
  </section>

  <section class="doc-layout">
    <section class="reader-panel">
      <PdfViewer client:load pdfUrl={pdfUrl} docSlug={entry.data.slug} title={entry.data.title} />
    </section>

    <aside class="notes-panel" aria-label="笔记预留区域">
      <div class="notes-panel__card">
        <p class="section-kicker">预留区域</p>
        <h2>笔记 / 备注</h2>
        <p class="notes-panel__summary">右侧区域先保留给后续记录能力，当前先作为空白占位区。</p>
        <div class="notes-panel__canvas" aria-hidden="true">
          <span>未来可放批注、摘录或阅读备注</span>
        </div>
      </div>
    </aside>

    <article class="doc-layout__content">
      <div class="rich-copy">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>
